        y = ((arg0->m[3][1] - arg1->y) + 5.0f) - (demoRandF() * 10.0f);
        z = ((arg0->m[3][2] - arg1->z) + 2.6666667f) - (demoRandF() * 8.0f);
    } else {
        x = arg0->m[3][0] + (arg0->m[1][0] * ((2.0f * uvRandF_LCG()) - 1.0f));
        y = arg0->m[3][1] + (arg0->m[1][1] * ((2.0f * uvRandF_LCG()) - 1.0f));
