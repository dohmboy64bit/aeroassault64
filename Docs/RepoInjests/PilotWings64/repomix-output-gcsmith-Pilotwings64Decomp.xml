    sp58 *= sp5C;
    sp54 *= sp5C;
    sp50 *= sp5C;

    sp4C = (arg8 * sp50) - (arg9 * sp54);
    sp48 = (arg9 * sp58) - (arg7 * sp50);
    sp44 = (arg7 * sp54) - (arg8 * sp58);

    temp_fv0_2 = sqrtf(SQ(sp4C) + SQ(sp48) + SQ(sp44));
    if (temp_fv0_2 != 0.0f) {
