    uvVtx(x, y + height - penWidth, 0, 0, 0, r, g, b, a);
    uvVtx(x + width, y + height - penWidth, 0, 0, 0, r, g, b, a);
    uvVtx(x + width, y + height, 0, 0, 0, r, g, b, a);
    uvVtx(x, y + height, 0, 0, 0, r, g, b, a);
    uvVtxEndPoly();

