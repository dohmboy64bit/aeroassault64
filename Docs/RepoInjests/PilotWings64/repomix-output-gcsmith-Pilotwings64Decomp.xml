        var_fv1 = 1.0f - ((2.0f * var_fa0) / therm->scale);
        dst->x = therm->unk20 * var_fv1 * dist * (y / dist);
        dst->y = -var_fv1 * therm->unk20 * dist * (x / dist);
    } else {
