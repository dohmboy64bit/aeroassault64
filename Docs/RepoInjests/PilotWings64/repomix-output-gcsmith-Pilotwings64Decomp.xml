struct TBD_ {
    u8 comm[parent.length];
};


struct VUE3_COMM {
    s32 unk0;
    s32 unk4;
    s32 unk8;
    s32 unkC;
    s32 modelId;
    s16 unk14;
    padding[parent.length - 0x16];
}; // size = 0x16 (should be 0x20?)

struct VUE3_QUAT_Unk8 {
    Vec4F unk0;
    s32 unk10;
    u8 pad14[0x4];
} [[static]]; // size = 0x18

