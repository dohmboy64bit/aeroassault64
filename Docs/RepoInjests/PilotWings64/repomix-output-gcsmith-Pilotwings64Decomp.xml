                FX_PROP_3(size * 0.6f, size * 0.6f, size),
                FX_PROP_END
            );
            // clang-format on
            if (i % 2) {
                uvFxProps(effect->fxIds[i], FX_PROP_8(0x13B), FX_PROP_END);
            } else {
                uvFxProps(effect->fxIds[i], FX_PROP_8(0x13A), FX_PROP_END);
