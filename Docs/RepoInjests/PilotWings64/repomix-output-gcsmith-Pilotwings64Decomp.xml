} [[static]]; // size = 0x78

// potential landing pad defined for Map (Level)
struct LevelLPAD {
    Vec3F pos;
    f32 angle;
    s32 isUsed [[comment("0 in FS, update from UWPT::LPAD")]];
    u8 type [[comment("type of landing pad model. updated from UWPT::LPAD")]];
    padding[3];
} [[static]]; // size = 0x18

struct LevelTOYS {
    Vec3F pos;
