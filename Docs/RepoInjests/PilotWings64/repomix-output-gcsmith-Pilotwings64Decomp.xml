STATIC_FUNC s32 oilPlantEventCb(UNUSED s32 proxId, s32 eventType, UNUSED s32 clientData) {
    switch (eventType) {
    case 0:
        break;
    case 2:
        if (sOilPlantRadarId != 0xFF) {
            hud_8031A874(sOilPlantRadarId);
        }
        uvFxProps(sOilPlantFxId, FX_PROP_3(0.0f, 0.0f, 0.0f), FX_PROP_END);
