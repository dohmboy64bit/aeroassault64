    Unk80362690_Unk0* sp20;

    sp20 = &D_80362690->unkC[D_80362690->unk9C];
    uvSprtDraw(0x1E);
    for (i = 0; i < sControlInfoCount; i++) {
        uvSprtDraw(i + 0x15);
    }
    func_80314154();
    uvGfxEnableCull(0, 0);
    contInfoDrawLineStrip(D_8034EC10);
    if (D_8034ED78[sp20->veh] != NULL) {
        contInfoDrawLineStrip(D_8034ED78[sp20->veh]);
    }
    uvGfxEnableCull(0, 1);
    func_803141E4();
}

