name: regress-external
on:
  pull_request_target:
    types: [ opened, synchronize ]
jobs:
  authorize:
    if: github.repository != github.event.pull_request.head.repo.full_name
    environment: ${{ github.event_name == 'pull_request_target' && github.event.pull_request.head.repo.full_name != github.repository && 'authorize-external' || 'authorize-internal' }}
    runs-on: ubuntu-latest
    steps:
      - run: echo ✓
  build:
    needs: authorize
    uses: ./.github/workflows/regress-validate.yaml
    secrets:
      SECRET_PASSPHRASE: ${{ secrets.SECRET_PASSPHRASE }}
      SECRET_REPO: ${{ secrets.SECRET_REPO }}
      SECRET_TOKEN: ${{ secrets.SECRET_TOKEN }}
</file>

<file path=".github/workflows/regress-internal.yaml">
name: regress-internal
on:
  push:
    branches: [ main ]
  pull_request:
    types: [ opened, synchronize ]
jobs:
  build:
    if: github.event_name == 'push' || github.repository == github.event.pull_request.head.repo.full_name
    uses: ./.github/workflows/regress-validate.yaml
    secrets: inherit
</file>

<file path=".github/workflows/regress-validate.yaml">
name: regress-validate
on:
  workflow_call:
    secrets:
      SECRET_PASSPHRASE: { required: true }
      SECRET_REPO: { required: true }
      SECRET_TOKEN: { required: true }
jobs:
  build:
    runs-on: ubuntu-latest
    strategy:
      fail-fast: false
      matrix:
        version: [ us ]
    steps:
    - name: Checkout
      uses: actions/checkout@v4
      with:
        ref: ${{ github.event.pull_request.head.sha || github.ref }}
    - name: Update Submodules
      run: git submodule update --init --recursive
    - name: Fetch Secrets
      uses: actions/checkout@v4
      with:
        repository: ${{ secrets.SECRET_REPO }}
        token: ${{ secrets.SECRET_TOKEN }}
        path: secret_repo
    - name: Decrypt Secrets
      working-directory: secret_repo
      run: ./decrypt_secret.sh
      env:
          SECRET_PASSPHRASE: ${{ secrets.SECRET_PASSPHRASE }}
          SECRET_BASENAME: pilotwings
          SECRET_VERSION: us
    - name: Install Packages
      run: sudo apt-get install -y git make git build-essential binutils-mips-linux-gnu python3 python3-pip
    - name: Build Dependencies
      run: make dependencies
    - name: Build
      run: make extract; make
    - name: Generate Progress Report
      run: python3 -m mapfile_parser objdiff_report --version ${{ matrix.version }}
    - name: Upload Progress Report
      uses: actions/upload-artifact@v4
      with:
        name: ${{ matrix.version }}_report
        path: build/progress.json
    - name: Discord Progress
      if: ${{ github.event_name == 'push' }}
      run: python3 tools/discord_progress.py --discord_url ${{ secrets.SECRET_DISCORD_WEBHOOK_URL }} --version ${{ matrix.version }}
    - name: Cleanup
      run: rm -f baserom.us.z64
</file>

