    uvVtx(x + penWidth, y, 0, 0, 0, r, g, b, a);
    uvVtx(x + penWidth, y + height, 0, 0, 0, r, g, b, a);
    uvVtx(x, y + height, 0, 0, 0, r, g, b, a);
    uvVtxEndPoly();

