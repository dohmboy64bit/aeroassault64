    GliderToy* glider;

    glider = &sGliderToys[idx];
    if (glider->objId != 0xFFFF) {
        *objId = glider->objId;
        *interval = glider->pathAngle / 360.0f;
        uvDobjGetPosm(*objId, 0, &pose);
        pos->x = pose.m[3][0];
        pos->y = pose.m[3][1];
        pos->z = pose.m[3][2];
    } else {
        *objId = 0xFFFF;
        *interval = 0.0f;
        pos->x = 0.0f;
        pos->y = 0.0f;
        pos->z = 0.0f;
    }
}

void gliderToySetInterval(s32 idx, f32 interval) {
