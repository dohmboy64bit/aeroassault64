        // clang-format off
        sp5C = 255.0f; \
        _uvDebugPrintf("clamping 1\n");
        // clang-format on
    }
    sp4C *= sp5C;
    sp48 *= sp5C;
    sp44 *= sp5C;

    arg7 = (sp54 * sp44) - (sp50 * sp48);
    arg8 = (sp50 * sp4C) - (sp58 * sp44);
    arg9 = (sp58 * sp48) - (sp54 * sp4C);

    temp_fv0_2 = sqrtf(SQ(arg7) + SQ(arg8) + SQ(arg9));
    if (temp_fv0_2 != 0.0f) {
