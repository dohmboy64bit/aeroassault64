            temp.m[1][2] = (fv0 * dst->m[1][2]) - (sp6C * dst->m[0][2]);
            temp.m[1][3] = (fv0 * dst->m[1][3]) - (sp6C * dst->m[0][3]);
            temp.m[2][0] = dst->m[2][0];
            temp.m[2][1] = dst->m[2][1];
            temp.m[2][2] = dst->m[2][2];
            temp.m[2][3] = dst->m[2][3];
            temp.m[3][0] = dst->m[3][0];
