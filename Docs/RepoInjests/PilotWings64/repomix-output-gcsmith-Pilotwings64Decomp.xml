// PW64 Level (map) data
struct UPWL {
    char tag[4];
    u32 length;
    const u64 Start = $;
    match (tag) {
        ("PAD "): u8 pad[length] [[hidden]];
        ("LEVL"): LevelLEVL levl;
        ("APTS"): LevelAPTS apts[length / sizeof(LevelAPTS)];
        ("BNUS"): LevelBNUS bnus[length / sizeof(LevelBNUS)];
        ("ESND"): LevelESND esnd[length / sizeof(LevelESND)];
