// 3VUE
struct VUE3 {
    char tag[4];
    u32 length;
    match (tag) {
        ("PAD "): u8 pad[length] [[hidden]];
        ("COMM"): VUE3_COMM comm;
        ("QUAT"): VUE3_QUAT quat;
        ("XLAT"): VUE3_XLAT xlat;
    }
};


// format PW64 u16 strings as ASCII representation
fn pw64ToAscii(ref auto val) {
    str result;
    for (u32 i = 0, i < sizeof(val) / 2, i += 1) {
        u16 v = val[i];
        if (v >= 0x60 && v <= 0xBF) { // [0x60-0xBF]: bold versions of [0x00-0x5F]
            v -= 0x60;
        }
        match (v) {
            (0x00 ... 0x09): result += char('0' + v);
            (0x0A ... 0x23): result += char('A' + v - 0xA);
            (0x24 ... 0x3D): result += char('a' + v - 0x24);
            (0x3E): result += "-";
            (0x3F): result += "#";
            (0x40): result += "<";
            (0x41): result += ">";
            (0x42): result += " ";
            (0x43): result += "\"";
            (0x44): result += "(";
            (0x45): result += ")";
            (0x46): result += "*";
            (0x47): result += "&";
            (0x48): result += ",";
            (0x49): result += ".";
            (0x4A): result += "/";
            (0x4B): result += "!";
            (0x4C): result += "?";
            (0x4D): result += "'";
            (0x4E): result += "#";
            (0x4F): result += ":";
            (0x50 ... 0x59): result += std::format("{}", v - 0x50);
            (0xD4): result += "%";
            (0xFD): result += " "; // actually "\t" but that renders oddly in ImHex
            (0xFE): result += "\n";
            (0xFF): result += "\0";
            (_): result += ".";
        }
    }
    return result;
};

struct ADAT {
    char tag[4];
    u32 length;
    match (tag) {
        ("PAD "): u8 pad[length] [[hidden]];
        ("SIZE"): u8 size[length];
        ("NAME"): char name[length];
        ("DATA"): u16 data[length / 2] [[format("pw64ToAscii")]];
        (_): u8 data[length]; // catch all for things like "SIZE"
    }
};


struct PDAT_PHDR {
    s32 unk0;
    s32 duration;
} [[static]]; // size = 0x8

struct PDAT_PPOS {
    Vec3F pos;
    Vec3F rot;
} [[static]]; // size = 0x18

struct PDAT_RHDR {
    s32 test;
    s32 unk4;
    s32 cls;
    s32 veh;
    s32 unk10;
} [[static,format("format_RHDR")]]; // size = 0x14

fn format_RHDR(PDAT_RHDR v) {
    return std::format("[ {} {} {} {} {} ]", v.test, v.unk4, v.cls, v.veh, v.unk10);
};

struct PDAT_RPKT {
    f32 time;
    f32 stickX;
    f32 stickY;
    u32 buttons;
} [[static]]; // size = 0x10

struct PDAT {
    char tag[4];
    u32 length;
    const u64 Start = $;
    match (tag) {
        ("PAD "): u8 pad[length] [[hidden]];
        ("PHDR"): PDAT_PHDR phdr;
        ("PPOS"): PDAT_PPOS pos[while($ - Start < length)];
        ("RHDR"): PDAT_RHDR rhdr;
        ("RPKT"): PDAT_RPKT rpkt[while($ - Start < length)];
        (_): u8 data[length];
    }
    padding[while (($ - Start) < length)]; // length is always to 8-bytes, not offsets
};


struct SPTH_SCP {
    s32 count;
    VecTimeVal vals[count];
}; // size = 0x4 + (0x8 * count)

struct SPTH {
    char tag[4];
    u32 length;
    const u64 Start = $;
    match (tag) {
        ("PAD "): u8 pad[length] [[hidden]];
        ("SCPH"): SPTH_SCP scph;
        ("SCPP"): SPTH_SCP scpp;
        ("SCPR"): SPTH_SCP scpp;
        ("SCPX"): SPTH_SCP scpx;
        ("SCPY"): SPTH_SCP scpy;
        ("SCPZ"): SPTH_SCP scpz;
        ("SCP#"): SPTH_SCP scp_;
        (_): u8 data[length];
    }
    padding[while (($ - Start) < length)]; // length is always to 8-bytes, not offsets
};


struct LevelLEVL {
    u8 countESND;
    u8 countWOBJ;
