    lookAt->l[1].l.dir[2] = (s32)MIN(arg9 * 128.0, 127.0) & 0xFF;
    lookAt->l[0].l.col[0] = 0;
    lookAt->l[0].l.col[1] = 0;
    lookAt->l[0].l.col[2] = 0;
    lookAt->l[0].l.pad1 = 0;
    lookAt->l[0].l.colc[0] = 0;
    lookAt->l[0].l.colc[1] = 0;
    lookAt->l[0].l.colc[2] = 0;
    lookAt->l[0].l.pad2 = 0;
