STATIC_FUNC void missiUpdatePos(void) {
    Mtx4F depthMtx;
    Mtx4F adjMtx;
    Mtx4F pathMtx;
    Mtx4F depthAdjMtx;
    f32 depthOffset;
    s32 tmpDiv;
    f32 depth;
    s32 temp_hi;
