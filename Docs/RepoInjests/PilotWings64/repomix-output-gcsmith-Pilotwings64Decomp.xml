    uvMat4MulBA(&gMatrixStack[gMatrixStackIdx], &gMatrixStack[gMatrixStackIdx - 1], src);
}

void _uvDbMstackPop(void) {
    if (gMatrixStackIdx < 0) {
        _uvDebugPrintf("_uvDbMstackPop: stack empty\n");
        return;
    }
    gMatrixStackIdx -= 1;
}

