        uvVtxBeginPoly();
        uvVtx(x + width - penWidth, y, 0, 0, 0, r, g, b, a);
        uvVtx(x + width, y, 0, 0, 0, r, g, b, a);
        uvVtx(x + width, y + height, 0, 0, 0, r, g, b, a);
        uvVtx(x + width - penWidth, y + height, 0, 0, 0, r, g, b, a);
