    uvFontSet(8);
    x += 36;
    y -= 12;
    uvFontColor(0xFF, 0xFF, 0xFF, 0xFF);
    uvFontScale(1.0, 1.0);
    dispSec = timeSec - ((timeSec / 60) * 60);
    uvSprintf(timeStr, "%02d'%02d\"%02d", timeSec / 60, dispSec, dispHundth);
    uvFontPrintStr(x, y, timeStr);
}

