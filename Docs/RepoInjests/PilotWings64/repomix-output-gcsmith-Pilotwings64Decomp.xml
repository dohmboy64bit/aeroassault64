// Visit https://github.com/ethteck/splat/wiki/Advanced-Reloc for documentation about this file
// entrypoint relocs
rom:0x001000 reloc:MIPS_HI16 symbol:kernel_BSS_START
rom:0x001008 reloc:MIPS_LO16 symbol:kernel_BSS_START

