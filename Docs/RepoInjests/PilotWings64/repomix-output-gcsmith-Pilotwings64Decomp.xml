    if (var_fv1 < 0.0f) {
        var_fv1 = 0.0f;
    }
    dst->z = therm->unk24 * var_fv1;
    if (z < therm->unk18) {
        var_fv1 = 1.0f - ((therm->unk18 - z) / therm->unk18);
    } else if (therm->unk1C < z) {
        var_fv1 = 1.0f - ((z - therm->unk1C) / (therm->height - therm->unk1C));
    } else {
