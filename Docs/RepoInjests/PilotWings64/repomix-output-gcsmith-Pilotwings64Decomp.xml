        for (i = 0; i < bmData->unk107; i++) {
            temp_fv1 = func_80313F08(&D_80359648, FABS(bmData->unk140[i]));
            switch (bmData->unk108[i]) {
            case 4:
                if ((bmData->unk15C != 0) && (bmData->unk104 == 2)) {
                    if (!(bmData->unk410 & 0x04)) {
                        bmData->unk410 |= 0x04;
