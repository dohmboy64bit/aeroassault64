f32 uvAtan2F(f32 y, f32 x) {
    s32 flag;
    f32 ret;
    f32 absY;
    f32 absX;
    f32 tmp;
    f32 absdiff;

    if ((x == 0.0f) && (y == 0.0f)) {
        return 0.0f;
    }
    absX = FABS(x);
    absY = FABS(y);
    flag = 0;
    if (absX < absY) {
        tmp = absX;
        absX = absY;
        absY = tmp;
        flag = 1;
    }
    tmp = (absY / absX);
    absdiff = FABS(absY - absX);
    ret = (PW_PI_4 * (absY / absX)) + (0.309f * absdiff * tmp);

    tmp = 0; // fake store to prevent emitting additional mov instr.
    if (x >= 0.0f) {
        if (flag) {
            ret = PW_PI_2 - ret;
        }
    } else if (flag) {
        ret = PW_PI_2 + ret;
    } else {
        ret = PW_PI - ret;
    }

    if (y >= 0.0f) {
        return ret;
    } else {
        return -ret;
    }
}
