} [[static]]; // size = 0x10

struct LevelTPTS {
    u8 unk0;
    u8 unk1[3];
    Vec3F unk4;
    f32 unk10;
    f32 unk14;
    s32 unk18;
    f32 unk1C;
    s32 unk20;
    f32 unk24;
