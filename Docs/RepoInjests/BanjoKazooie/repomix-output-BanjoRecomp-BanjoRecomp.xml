    float texcoord_t = output_y_adjusted * DEFAULT_FRAMEBUFFER_HEIGHT * 2.0f;

    // Convert the texcoords to fixed point with 5 bits of fractional precision.
    v->v.tc[0] = (s32)(texcoord_s * 32.0f);
    v->v.tc[1] = (s32)(texcoord_t * 32.0f);
}

