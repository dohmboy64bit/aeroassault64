        if (recursion_depth == 0) {
            static u32 spawn_rate_counter = 0;
            spawn_rate_counter++;

            if (spawn_rate_counter == spawn_rate_frequency) {
                recursion_depth++;
                func_802F87B0(this);
                recursion_depth--;
                spawn_rate_counter = 0;
