    gSPSegment(mygdl++, SEGMENT_3, d);
    gSPSegment(mygdl++, SEGMENT_5, modelInst2->vertices[(modelInst2->unk34 >> 1) & 0x1]);
    gSPDisplayList(mygdl++, OS_K0_TO_PHYSICAL(modelInst2->displayList));

    dl_set_all_dirty();
    tex_render_reset();

    // @recomp: Pop tag
    gEXPopMatrixGroup(mygdl++, G_MTX_MODELVIEW);

    *gdl = mygdl;
    *rspMtxs = outRspMtxs;
}
