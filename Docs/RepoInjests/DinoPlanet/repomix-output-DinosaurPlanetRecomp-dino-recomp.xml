TARGET = patches.elf

CC      = clang
LD      = ld.lld

BUILD_DIR = build

CFLAGS   := -target mips -mips2 -mabi=32 -O2 -G0 -mno-abicalls -mno-odd-spreg -mno-check-zero-division \
			-fomit-frame-pointer -ffast-math -fno-unsafe-math-optimizations -fno-builtin \
			-Wall -Wextra -Wno-incompatible-library-redeclaration -Wno-unused-parameter -Wno-unknown-pragmas -Wno-unused-variable -Wno-missing-braces -Wno-unsupported-floating-point-opt -fno-strict-aliasing
CPPFLAGS := -nostdinc -D_LANGUAGE_C -D_MIPS_SZLONG=32 -DF3DEX_GBI_2 -DMIPS -DAVOID_UB -I src -I include -I ../lib/dino-recomp-decomp-bridge/dinosaur-planet/include -I ../lib/dino-recomp-decomp-bridge/dinosaur-planet/src -I ../lib/dino-recomp-decomp-bridge/include -I../lib/rt64/include
LDFLAGS  := -nostdlib -T patches.ld -T syms.ld -Map $(BUILD_DIR)/patches.map --unresolved-symbols=ignore-all --emit-relocs

C_SRCS := $(wildcard src/*.c)
C_SRCS += $(wildcard src/core/*.c)
C_SRCS += $(wildcard src/core/libnaudio/*.c)
C_SRCS += $(wildcard src/core/libultra/*.c)
C_SRCS += $(wildcard src/core/mp3/*.c)
C_SRCS += $(wildcard src/custom/*.c)
C_SRCS += $(wildcard src/custom/builtin_dbgui/*.c)
C_SRCS += $(wildcard src/dlls/*.c)
C_SRCS += $(wildcard src/reasset/*.c)
C_SRCS += $(wildcard src/reasset/files/*.c)
C_SRCS += $(wildcard src/reasset/special/*.c)
C_OBJS := $(C_SRCS:%.c=$(BUILD_DIR)/%.o)
C_DEPS := $(C_SRCS:%.c=$(BUILD_DIR)/%.d)

BUILD_DIRS := $(BUILD_DIR) $(BUILD_DIR)/src \
	$(BUILD_DIR)/src/core $(BUILD_DIR)/src/core/libnaudio $(BUILD_DIR)/src/core/libultra $(BUILD_DIR)/src/core/mp3 \
	$(BUILD_DIR)/src/custom $(BUILD_DIR)/src/custom/builtin_dbgui \
	$(BUILD_DIR)/src/dlls \
	$(BUILD_DIR)/src/reasset $(BUILD_DIR)/src/reasset/files $(BUILD_DIR)/src/reasset/special

$(BUILD_DIR)/$(TARGET): $(C_OBJS) patches.ld syms.ld
	$(LD) $(C_OBJS) $(LDFLAGS) -o $@
    
$(BUILD_DIRS):
ifeq ($(OS),Windows_NT)
	mkdir $(subst /,\,$@)
else
	mkdir -p $@
endif

$(C_OBJS): $(BUILD_DIR)/%.o : %.c | $(BUILD_DIRS)
	$(CC) $(CFLAGS) $(CPPFLAGS) $< -MMD -MF $(@:.o=.d) -c -o $@

clean:
	rm -rf $(BUILD_DIR)

-include $(C_DEPS)

.PHONY: clean
