    config.rr_option        = from_or_default(j, "rr_option",       rr_default);
    config.hpfb_option      = from_or_default(j, "hpfb_option",     hpfb_default);
    config.rr_manual_value  = from_or_default(j, "rr_manual_value", rr_manual_default);
