            }

            if (dbgui_begin_tab_item("Framebuffer FX", NULL)) {
                fbfx_tab();
                dbgui_end_tab_item();
            }

            if (dbgui_begin_tab_item("Hacks", NULL)) {
                hacks_tab();
                dbgui_end_tab_item();
            }

            if (dbgui_begin_tab_item("Recomp", NULL)) {
                recomp_tab();
                dbgui_end_tab_item();
            }
            
            dbgui_end_tab_bar();
        }
    }
    dbgui_end();
}
