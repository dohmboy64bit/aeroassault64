<file path=".github/workflows/build.yml">
name: build
on:
  workflow_dispatch:
    secrets:
      PRIVATE_REPO_PAT:
        required: true
concurrency:
  group: ${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true
jobs:
  # Linux (native & AppImage)
  build-linux:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v6
        with:
          ref: ${{ github.event.pull_request.head.sha || github.ref }}
          submodules: recursive
      - name: Checkout baserom
        uses: actions/checkout@v6
        with:
          repository: DinosaurPlanetRecomp/dino-recomp-private
          token: ${{ secrets.PRIVATE_REPO_PAT }}
          path: baserom
      - name: Extract baserom
        run: |
          unzip baserom/baserom.patched.z64.zip -d ./
      - name: Install apt packages
        run: |
          sudo apt-get update
          sudo apt-get install cmake ninja-build libsdl2-dev libdbus-1-dev libfreetype-dev lld llvm clang
      - name: Build N64Recomp & RSPRecomp
        run: |
          cd lib/N64Recomp

          cmake -DCMAKE_BUILD_TYPE=Release -DCMAKE_MAKE_PROGRAM=ninja -G Ninja -S . -B cmake-build
          cmake --build cmake-build --config Release --target N64RecompCLI -j $(nproc)
          cmake --build cmake-build --config Release --target RSPRecomp -j $(nproc)

          # Copy N64Recomp & RSPRecomp to root directory
          cp cmake-build/N64Recomp ../..
          cp cmake-build/RSPRecomp ../..
      - name: Run N64Recomp & RSPRecomp
        run: |
          ./N64Recomp dino.toml
          ./RSPRecomp aspMain.toml
      - name: Build DinoRecomp
        run: |
          cmake -DCMAKE_BUILD_TYPE=RelWithDebInfo -DCMAKE_CXX_COMPILER=clang++ -DCMAKE_C_COMPILER=clang -DCMAKE_MAKE_PROGRAM=ninja -G Ninja -S . -B cmake-build
          cmake --build cmake-build --config RelWithDebInfo --target DinosaurPlanetRecompiled -j $(nproc)
      - name: Split Debug Information
        run: |
          objcopy --only-keep-debug cmake-build/DinosaurPlanetRecompiled cmake-build/DinosaurPlanetRecompiled.debug
          strip --strip-debug --strip-unneeded cmake-build/DinosaurPlanetRecompiled
      - name: Remove scss directory
        run: rm -rf assets/scss
      - name: Prepare Native Archive
        run: |
          cp cmake-build/DinosaurPlanetRecompiled DinosaurPlanetRecompiled
          tar -czf DinosaurPlanetRecompiled-${{ runner.os }}-x64.tar.gz DinosaurPlanetRecompiled assets/ recompcontrollerdb.txt
      - name: Archive DinoRecomp (Native)
        uses: actions/upload-artifact@v7
        with:
          path: DinosaurPlanetRecompiled-${{ runner.os }}-x64.tar.gz
          archive: false
      - name: Archive DinoRecomp (Debug)
        uses: actions/upload-artifact@v7
        with:
          name: DinosaurPlanetRecompiled-${{ runner.os }}-x64-Debug
          path: cmake-build/DinosaurPlanetRecompiled.debug
      - name: Build AppImage
        run: |
          cd deploy/appimage

          # Download linuxdeploy
          curl -sSfLO "https://github.com/linuxdeploy/linuxdeploy/releases/download/continuous/linuxdeploy-x86_64.AppImage"
          chmod a+x ./linuxdeploy-x86_64.AppImage

          # Set up AppDir (stuff linuxdeploy can't do)
          mkdir -p AppDir/usr/bin/
          mkdir -p AppDir/usr/share/metainfo/
          cp ../io.github.dinosaurplanetrecomp.dino_recomp.metainfo.xml AppDir/usr/share/metainfo/
          cp -R ../../assets/ AppDir/usr/bin/
          cp ../../recompcontrollerdb.txt AppDir/usr/bin/

          # Create AppImage
          NO_STRIP=true ./linuxdeploy-x86_64.AppImage \
            --appdir AppDir \
            --executable ../../cmake-build/DinosaurPlanetRecompiled \
            --desktop-file ../io.github.dinosaurplanetrecomp.dino_recomp.desktop \
            --icon-file ../../icons/512.png \
            --icon-filename io.github.dinosaurplanetrecomp.dino_recomp \
            --output appimage
          mv Dinosaur_Planet:_Recompiled-x86_64.AppImage DinosaurPlanetRecompiled-${{ runner.os }}-x64.AppImage
      - name: Archive DinoRecomp (AppImage)
        uses: actions/upload-artifact@v7
        with:
          path: deploy/appimage/DinosaurPlanetRecompiled-${{ runner.os }}-x64.AppImage
          archive: false
  # Linux (Flatpak)
  build-linux-flatpak:
    runs-on: ubuntu-latest
    env:
      FLATPAK_ID: "io.github.dinosaurplanetrecomp.dino_recomp"
      FREEDESKTOP_VERSION: 24.08
      LLVM_VERSION: 19
    steps:
      - name: Checkout
        uses: actions/checkout@v6
        with:
          ref: ${{ github.event.pull_request.head.sha || github.ref }}
          submodules: recursive
      - name: Checkout baserom
        uses: actions/checkout@v6
        with:
          repository: DinosaurPlanetRecomp/dino-recomp-private
          token: ${{ secrets.PRIVATE_REPO_PAT }}
          path: baserom
      - name: Extract baserom
        run: |
          unzip baserom/baserom.patched.z64.zip -d ./
      - name: Install Linux Dependencies
        run: |
          sudo apt-get update
          sudo apt-get install -y flatpak-builder lld
      - name: Install apt packages
        run: sudo apt-get install flatpak-builder clang lld
      - name: Prepare Flatpak
        run: |
          flatpak --user remote-add --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo
          flatpak --user install -y flathub org.freedesktop.Sdk//${{ env.FREEDESKTOP_VERSION }}
          flatpak --user install -y flathub org.freedesktop.Sdk.Extension.llvm${{ env.LLVM_VERSION }}//${{ env.FREEDESKTOP_VERSION }}
      - name: Build DinoRecomp
        run: |
          git config --global protocol.file.allow always
          make -C patches CC=clang LD=ld.lld
          cd deploy/flatpak
          flatpak-builder --user --force-clean --install-deps-from=flathub --repo=repo builddir ${{ env.FLATPAK_ID }}.yml
          flatpak build-bundle repo ${{ env.FLATPAK_ID }}.flatpak ${{ env.FLATPAK_ID }} --runtime-repo=https://flathub.org/repo/flathub.flatpakrepo
          flatpak build-bundle repo ${{ env.FLATPAK_ID }}.Debug.flatpak ${{ env.FLATPAK_ID }}.Debug --runtime --runtime-repo=https://flathub.org/repo/flathub.flatpakrepo
          mv ${{ env.FLATPAK_ID }}.flatpak DinosaurPlanetRecompiled-${{ runner.os }}-x64.flatpak
          mv ${{ env.FLATPAK_ID }}.Debug.flatpak DinosaurPlanetRecompiled-${{ runner.os }}-x64.Debug.flatpak
      - name: Upload Artifact
        uses: actions/upload-artifact@v7
        with:
          path: ./deploy/flatpak/DinosaurPlanetRecompiled-${{ runner.os }}-x64.flatpak
          archive: false
      - name: Upload Artifact (Debug)
        uses: actions/upload-artifact@v7
        with:
          path: ./deploy/flatpak/DinosaurPlanetRecompiled-${{ runner.os }}-x64.Debug.flatpak
          archive: false
  # Windows
  build-windows:
    runs-on: windows-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v6
        with:
          ref: ${{ github.event.pull_request.head.sha || github.ref }}
          submodules: recursive
      - name: Install Windows Dependencies
        run: |
          choco install ninja
      - name: Download portable LLVM
        run: |
          $ProgressPreference = 'SilentlyContinue'
          Invoke-WebRequest -Uri "https://github.com/llvm/llvm-project/releases/download/llvmorg-19.1.3/LLVM-19.1.3-Windows-X64.tar.xz" -OutFile "LLVM.tar.xz"
          New-Item -ItemType Directory -Path portable-llvm > $null
          7z x LLVM.tar.xz
          7z x LLVM.tar -oportable-llvm
      - name: Configure Developer Command Prompt
        uses: TheMrMilchmann/setup-msvc-dev@v4
        with:
          arch: x64
      - name: Checkout baserom
        uses: actions/checkout@v6
        with:
          repository: DinosaurPlanetRecomp/dino-recomp-private
          token: ${{ secrets.PRIVATE_REPO_PAT }}
          path: baserom
      - name: Extract baserom
        run: |
          Expand-Archive baserom\baserom.patched.z64.zip .\
      - name: Build N64Recomp & RSPRecomp
        run: |
          cd lib/N64Recomp

          set $env:PATH="$env:USERPROFILE/.cargo/bin;$env:PATH"
          $cpuCores = (Get-CimInstance -ClassName Win32_Processor).NumberOfLogicalProcessors

          cmake -DCMAKE_BUILD_TYPE=Release -DCMAKE_MAKE_PROGRAM=ninja -G Ninja -S . -B cmake-build
          cmake --build cmake-build --config Release --target N64RecompCLI -j $cpuCores
          cmake --build cmake-build --config Release --target RSPRecomp -j $cpuCores

          # Copy N64Recomp & RSPRecomp to root directory
          cp cmake-build/N64Recomp.exe ../..
          cp cmake-build/RSPRecomp.exe ../..
      - name: Run N64Recomp & RSPRecomp
        run: |
          ./N64Recomp.exe dino.toml
          ./RSPRecomp.exe aspMain.toml
      - name: Build DinoRecomp
        run: |
          set $env:PATH="$env:USERPROFILE/.cargo/bin;$env:PATH"
          $cpuCores = (Get-CimInstance -ClassName Win32_Processor).NumberOfLogicalProcessors

          # remove LLVM from PATH so it doesn't overshadow the one provided by VS
          $env:PATH = ($env:PATH -split ';' | Where-Object { $_ -ne 'C:\Program Files\LLVM\bin' }) -join ';'

          cmake -DCMAKE_BUILD_TYPE=RelWithDebInfo -DCMAKE_CXX_COMPILER=clang-cl -DCMAKE_C_COMPILER=clang-cl -DCMAKE_MAKE_PROGRAM=ninja -DPATCHES_C_COMPILER="..\portable-llvm\LLVM-19.1.3-Windows-X64\bin\clang" -DPATCHES_LD="..\portable-llvm\LLVM-19.1.3-Windows-X64\bin\ld.lld" -G Ninja -S . -B cmake-build -DCMAKE_CXX_FLAGS="-Xclang -fexceptions -Xclang -fcxx-exceptions"
          cmake --build cmake-build --config RelWithDebInfo --target DinosaurPlanetRecompiled -j $cpuCores
      - name: Prepare Archive
        run: |
          Move-Item -Path "cmake-build/DinosaurPlanetRecompiled.exe" -Destination "DinosaurPlanetRecompiled.exe"
          Move-Item -Path "cmake-build/dxcompiler.dll" -Destination "dxcompiler.dll"
          Move-Item -Path "cmake-build/dxil.dll" -Destination "dxil.dll"
          Move-Item -Path "cmake-build/SDL2.dll" -Destination "SDL2.dll"
          Move-Item -Path "cmake-build/DinosaurPlanetRecompiled.pdb" -Destination "DinosaurPlanetRecompiled.pdb"
          Remove-Item -Path "assets/scss" -Recurse -Force
      - name: Archive DinoRecomp
        uses: actions/upload-artifact@v7
        with:
          name: DinosaurPlanetRecompiled-${{ runner.os }}-x64
          path: |
            DinosaurPlanetRecompiled.exe
            dxcompiler.dll
            dxil.dll
            SDL2.dll
            assets/
            recompcontrollerdb.txt
      - name: Archive Debug Files
        uses: actions/upload-artifact@v7
        with:
          name: DinosaurPlanetRecompiled-${{ runner.os }}-x64-PDB
          path: |
            DinosaurPlanetRecompiled.pdb
