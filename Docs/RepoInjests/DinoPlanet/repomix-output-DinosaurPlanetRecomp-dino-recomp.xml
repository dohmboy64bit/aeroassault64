# Config file for Dinosaur Planet Recompilation.

[input]
entrypoint = 0x80000400
# Paths are relative to the location of this config file.
output_func_path = "RecompiledFuncs"
rom_file_path = "baserom.patched.z64"
symbols_file_path = "lib/dino-recomp-decomp-bridge/dino.syms.toml"
relocatable_sections_path = "lib/dino-recomp-decomp-bridge/dino.dlls.txt"

[patches]
stubs = [
    "test_write",
    "check_dongle",
]

ignored = [
    "__osMakeMotorData",
    # unused problematic funcs
    "func_80011588",
    "func_80011490",
    "NOTosContSetch"
]

renamed = [
    "acos",
    "asin",
    "_itoa",
    "strcasecmp",
    "strncasecmp",
]

# Enable mips3 float mode for mips3 hasm
[[patches.hook]]
before_vram = 0x80014FEC
