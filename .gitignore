# ROMs (keep directory, not dumps)
roms/*.z64
roms/*.n64
roms/*.v64
roms/*.rom
!roms/.gitkeep

# Legacy / accidental ROM paths under Docs
Docs/Rom/*.z64
Docs/Rom/*.n64
Docs/Rom/*.v64

# Build outputs
build/
build-root/
build-root-no-mm/
build-root-afa-product/
build-root-vs2022/
build-root-vs2022-afa-product/
build-engine/
build-engine-vs2022/
out/
cmake-build-*/
CMakeFiles/
CMakeCache.txt
*.cmake
!CMakePresets.json

# IDE / OS
.vs/
.vscode/*.log
*.user
*.suo
.DS_Store
Thumbs.db

# Local N64Recomp clone used only for one-off builds (do not commit)
tools/N64Recomp-src/

# Python / splat
.venv/
venv/
__pycache__/
*.pyc

# N64Recomp output (regenerate: `tools/N64Recomp.exe` + `config/aerofighters_assault.n64recomp.toml`; see `tools/README.txt`)
RecompiledFuncs/*.c
RecompiledFuncs/*.h
RecompiledFuncs/*.cpp
RecompiledFuncs/*.inl
!RecompiledFuncs/README.txt
!RecompiledFuncs/.gitkeep

# AFA USA ROM XXH3 for optional second GameEntry (see tools/compute_aero_rom_xxh3.py, lib/Zelda64Recomp/CMakeLists.txt)
config/.afa_usa_rom_xxh3

# Generated asm (when splat emits into repo — adjust path if you use asm/ at root)
asm/

# splat cache / extracted bins (regenerated)
.splache/
assets/*.bin
